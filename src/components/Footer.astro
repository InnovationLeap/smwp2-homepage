---
interface Props {
  marginTop?: string;
}

const { marginTop = "mt-12" } = Astro.props;
---

<footer class={`border-t border-gray-200 py-6 dark:border-gray-800 ${marginTop}`}>
  <div class="max-w-6xl mx-auto px-4 text-center">
    <p class="text-gray-600 text-sm dark:text-gray-400">
      Copyright &copy; 2026 <a href="https://inleap.marioforever.net/" target="_blank" rel="noopener noreferrer">INNOVATION LEAP</a>. Mario and its related copyrights belong to Nintendo.
    </p>
  </div>
</footer>
